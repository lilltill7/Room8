# Room8 Backend — Environment Variables
# Copy this file to .env and fill in your values

# Flask environment
FLASK_ENV=production

# Secret key for sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret

# Database URL
# SQLite (default, good for development and small deploys):
DATABASE_URL=sqlite:///room8.db
# PostgreSQL (recommended for production on Render):
# DATABASE_URL=postgresql://user:password@host:5432/room8

# Allowed CORS origins — comma-separated list
# Development: http://localhost:5173,http://127.0.0.1:5173
# Production:  set to your deployed frontend URL (e.g. Vercel/Netlify/Render)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload directory (relative to backend root)
UPLOAD_FOLDER=uploads
